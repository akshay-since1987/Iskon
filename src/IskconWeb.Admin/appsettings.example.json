{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiConfig": {
    "BaseUrl": "https://localhost:7001",
    "TimeoutSeconds": 30
  },
  "AdminConfig": {
    "DefaultTempleId": "11111111-1111-1111-1111-111111111111",
    "ItemsPerPage": 20,
    "MaxUploadSizeMB": 5
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/admin-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}